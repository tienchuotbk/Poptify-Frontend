# Public client-side env — Vite inline mọi biến VITE_* vào bundle.
# TUYET DOI KHONG dat secret (offline/admin token, API secret, webhook secret) o day.

# Shopify app client API key (public — an toan de expose). Phase 0-5 dung placeholder.
VITE_SHOPIFY_API_KEY=your-shopify-app-client-api-key

# Base URL cua Poptify Backend (REST API). Dev: BE local.
VITE_API_BASE_URL=http://localhost:3000
